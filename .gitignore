# .gitignore — Root level (áp dụng cho cả repo mono-repo)
# Backend-specific: xem backend/.gitignore (do Spring Initializr tạo)
# Frontend-specific: xem frontend/.gitignore (do Vite tạo)

# ─── Environment / Secrets ───────────────────────────────────────────────────
# KHÔNG bao giờ commit .env (chứa secrets thật)
# Chỉ commit .env.example (template, không có giá trị thật)
.env
.env.local
.env.*.local

# ─── OS / Editor ─────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
Desktop.ini

# ─── IDE ─────────────────────────────────────────────────────────────────────
.idea/
*.iml
*.iws
*.ipr
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ─── Docker ───────────────────────────────────────────────────────────────────
# Không ignore docker-compose.yml (cần commit để dev dùng local)
# Chỉ ignore override file nếu có
docker-compose.override.yml

node_modules/
dist/
