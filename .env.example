# .env.example — Mẫu biến môi trường cho Local Development
#
# HƯỚNG DẪN:
#   1. Sao chép file này: cp .env.example .env
#   2. Điền giá trị thật vào .env (KHÔNG commit file .env lên Git)
#   3. Chạy: docker compose up -d
#
# Xem docs/11-DEPLOYMENT.md mục 2 để biết biến nào cần thiết cho Production.

# ─── PostgreSQL (Local Docker) ────────────────────────────────────────────────
POSTGRES_DB=itam_dev
POSTGRES_USER=itam
POSTGRES_PASSWORD=itam_local_dev
POSTGRES_PORT=5432

# ─── Backend ──────────────────────────────────────────────────────────────────
BACKEND_PORT=8080

# JWT — tạo secret ngẫu nhiên đủ dài (≥ 256-bit / 32 ký tự hex trở lên)
# Lệnh tạo nhanh (macOS/Linux): openssl rand -hex 64
JWT_SECRET=change-me-to-a-random-256-bit-secret-before-running
JWT_ACCESS_TOKEN_EXPIRATION=1800000
JWT_REFRESH_TOKEN_EXPIRATION=2592000000

# CORS — domain Frontend được phép gọi API
# Local: http://localhost:5173 (Vite dev server)
# Production: https://your-app.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Cookie Secure flag
# false = Local dev HTTP  (phải tắt, nếu không browser sẽ không gửi cookie qua HTTP)
# true  = Production HTTPS (bật để bảo mật)
COOKIE_SECURE=false

# ─── Cloudinary (Upload ảnh thiết bị & QR) ────────────────────────────────────
# Lấy tại: https://console.cloudinary.com → Dashboard
# Để trống nếu không test tính năng upload ảnh ở local
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── SendGrid (Email — reset password, notification) ──────────────────────────
# Lấy tại: https://app.sendgrid.com → Settings → API Keys
# Để trống nếu không test tính năng email ở local
SENDGRID_API_KEY=

# ─── Spring Profile ───────────────────────────────────────────────────────────
# Để trống cho local dev (dùng log text thường, dễ đọc trên terminal)
# Đặt "production" trên Render để bật JSON structured logging
SPRING_PROFILES_ACTIVE=

# ─── Frontend (Vite) ──────────────────────────────────────────────────────────
# Dùng trong frontend/.env (file riêng, prefix VITE_ bắt buộc để Vite expose ra client)
# VITE_API_BASE_URL=http://localhost:8080/api/v1
