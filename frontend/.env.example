# frontend/.env.example
# Sao chép thành frontend/.env rồi điền giá trị thật (file .env KHÔNG được commit)
#
# Vite yêu cầu prefix VITE_ để expose biến ra client-side (import.meta.env)
# Biến KHÔNG có prefix VITE_ sẽ không xuất hiện trong bundle (security feature của Vite)

# URL API Backend
# Local dev:   http://localhost:8080/api/v1
# Production:  https://<your-render-service>.onrender.com/api/v1
VITE_API_BASE_URL=http://localhost:8080/api/v1
